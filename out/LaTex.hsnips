snippet section "UNNUMBERED SECTION" iA
\section*{$1}$2
endsnippet

snippet subsection "UNNUMBERED SUBSECTION" iA
\subsection*{$1}$2
endsnippet

snippet subsubsection "UNNUMBERED SUBSUBSECTION" iA
