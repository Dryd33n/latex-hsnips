endsnippet

snippet newp "NEW PAGE" iA
\newpage
endsnippet

snippet text "TEXT" iA
\text{$1}$2
endsnippet

snippet bold "BOLD TEXT" iA
\textbf{$1}$2
endsnippet

snippet und "UNDERLINE" iA
\underline{$1}$2
endsnippet

snippet `table;(\d);(\d)` "INSERT TABLE" iA
`` rv = `\\begin{table}[htp]
     \\centering
     \\begin{tabular}{`+'c'.repeat(m[1])+'}\n'
     let line = ('   '+'&   '.repeat(m[1]-1) + '\\'+ '\\'+'\\'+'\n')
     rv += line.repeat(m[2]) 
     rv += `\\end{tabular}
    \\end{table}\\\\\\\\` 
``
endsnippet

snippet articletemplate "ARTICLE TEMPLATE" iA
\documentclass{article}
\usepackage[legalpaper, portrait, margin=0.5in]{geometry}
\usepackage {amsmath}
\usepackage {amssymb}
\usepackage {enumerate}

\title{$1}
\author{$2}
\date{$3}

\begin{document}

\maketitle
\newpage

\end{document}
endsnippet

